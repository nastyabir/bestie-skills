{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "bestie-skills entry frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name", "source_url", "author", "license", "agents", "category",
    "summary", "use_cases", "why", "status", "security", "added_by", "added_date"
  ],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "source_url": { "type": "string", "pattern": "^https?://" },
    "author": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["claude-code", "codex", "cursor", "any"] }
    },
    "category": {
      "enum": ["coding", "research", "writing", "data", "devops", "workflow", "meta"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "use_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "why": { "type": "string", "minLength": 1 },
    "status": { "enum": ["untested", "tested", "endorsed"] },
    "security": { "enum": ["pass", "flagged", "manual-review"] },
    "added_by": { "type": "string", "minLength": 1 },
    "added_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
